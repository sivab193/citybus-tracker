# CityBus Bot — Production Configuration
# Copy to .env and fill in values.

# ─── Telegram ───
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_IDS=                          # comma-separated Telegram user IDs

# ─── MongoDB ───
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=citybus

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0
REDIS_ARRIVAL_TTL=30                # seconds

# ─── GTFS# Real-Time endpoints (GTFS-RT protobuf)
# Provide URLs pointing directly to the .pb static files
GTFS_RT_TRIP_UPDATES_URL=https://example.com/gtfs-rt/trip_updates.pb
GTFS_RT_VEHICLE_POSITIONS_URL=https://example.com/gtfs-rt/vehicle_positions.pb
GTFS_RT_SERVICE_ALERTS_URL=https://example.com/gtfs-rt/service_alerts.pb

# ─── API Server ───
API_PORT=8000
API_RATE_LIMIT=100/minute
API_BASE_URL=http://localhost:8000
ADMIN_API_KEY=change_me_in_production

# ─── Worker ───
WORKER_POLL_INTERVAL=10             # seconds

# ─── Heartbeat (optional) ───
ENABLE_HEARTBEAT=false
HEARTBEAT_URL=http://localhost:1903/heartbeat
HEARTBEAT_INTERVAL=60
